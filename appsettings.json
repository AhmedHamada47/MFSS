{
    "Migration": {
        "Name": "my-migration",
        "Mode": "migrate",
        "DryRun": false,
        "FreshStart": false,
        "ParallelDownloads": 4,
        "MaxRetries": 3,
        "RateLimitPerSecond": 10,
        "MaxFileSizeMB": 100
    },
    "SourceDb": {
        "ConnectionString": "Data Source=(localdb)\\ProjectModels;Initial Catalog=22-6Migration;Integrated Security=True;TrustServerCertificate=True;",
        "Tables": [
            {
                "TableName": "MediaFiles",
                "UrlColumn": "FilePath",
                "IdColumn": "MediaId"
            },
            {
                "TableName": "Users",
                "UrlColumn": "ProfilePictureUrl",
                "IdColumn": "UserId"
            }
        ]
    },
    "SourceFileSystem": {
        "Type": "http",
        "BasePath": "",
        "_comment_source": "Supported types: http, s3, azure, gcs, local. Examples below:",
        "_example_s3_source": {
            "Type": "s3",
            "BucketName": "my-source-bucket",
            "Region": "us-east-1",
            "AccessKey": "${AWS_SOURCE_ACCESS_KEY}",
            "SecretKey": "${AWS_SOURCE_SECRET_KEY}"
        },
        "_example_azure_source": {
            "Type": "azure",
            "AzureConnectionString": "${AZURE_SOURCE_CONNECTION_STRING}",
            "ContainerName": "my-source-container"
        },
        "_example_gcs_source": {
            "Type": "gcs",
            "GcsBucket": "my-source-bucket",
            "GcsCredentialPath": "/path/to/service-account.json",
            "GcsProjectId": "my-project-id"
        }
    },
    "DestinationFileSystem": {
        "Type": "s3",
        "BucketName": "my-destination-bucket",
        "Region": "us-east-1",
        "AccessKey": "${AWS_DEST_ACCESS_KEY}",
        "SecretKey": "${AWS_DEST_SECRET_KEY}",
        "_comment_dest": "Supported types: s3, azure, gcs, local. Examples below:",
        "_example_azure_dest": {
            "Type": "azure",
            "AzureConnectionString": "${AZURE_DEST_CONNECTION_STRING}",
            "ContainerName": "my-dest-container"
        },
        "_example_gcs_dest": {
            "Type": "gcs",
            "GcsBucket": "my-dest-bucket",
            "GcsCredentialPath": "/path/to/service-account.json",
            "GcsProjectId": "my-project-id"
        },
        "_example_local_dest": {
            "Type": "local",
            "BasePath": "/var/data/migrated-files"
        }
    },
    "DestinationDb": {
        "ConnectionString": "Data Source=(localdb)\\ProjectModels;Initial Catalog=Test MFss;Integrated Security=True;TrustServerCertificate=True;",
        "SeparateTablesPerSource": true
    },
    "ThirdDb": {
        "Enabled": false,
        "ConnectionString": "Data Source=(localdb)\\ProjectModels;Initial Catalog=4-6 LastContent;Integrated Security=True;TrustServerCertificate=True;",
        "UpdateQuery": "UPDATE media SET url = {url} WHERE id = {id}"
    }
}
